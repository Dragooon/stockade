#!/usr/bin/env bash
# Stockade platform launcher.
#
# Usage:
#   stockade              Start proxy + orchestrator (full platform)
#   stockade proxy        Start proxy only
#   stockade validate     Validate config without starting

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

# ── Preflight ──
if ! command -v node &>/dev/null; then
  echo "[stockade] error: node is required" >&2
  exit 1
fi

CMD="${1:-}"

# ── stockade validate ──
if [[ "$CMD" == "validate" ]]; then
  exec node --import tsx packages/orchestrator/src/validate.ts
fi

# ── stockade proxy ──
if [[ "$CMD" == "proxy" ]]; then
  echo "[stockade] starting proxy (watching for changes)..."
  exec npx tsx watch packages/proxy/src/index.ts
fi

# ── stockade (full platform) ──
if ! command -v docker &>/dev/null; then
  echo "[stockade] warning: docker not found — container isolation disabled"
fi

PROXY_PID=""
cleanup() {
  echo ""
  echo "[stockade] shutting down..."
  if [[ -n "$PROXY_PID" ]]; then
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

echo "[stockade] starting proxy (watching for changes)..."
npx tsx watch packages/proxy/src/index.ts &
PROXY_PID=$!
sleep 1

# Orchestrator with restart loop
EXIT_CODE=75
while [ "$EXIT_CODE" -eq 75 ]; do
  echo "[stockade] installing dependencies..."
  pnpm install --frozen-lockfile 2>&1 | tail -1
  echo "[stockade] building..."
  pnpm build 2>&1 | tail -1
  echo "[stockade] starting orchestrator..."
  node --import tsx packages/orchestrator/src/index.ts
  EXIT_CODE=$?
  if [ "$EXIT_CODE" -eq 75 ]; then
    echo "[stockade] orchestrator requested restart, restarting..."
    sleep 1
  fi
done
echo "[stockade] orchestrator exited with code $EXIT_CODE"
