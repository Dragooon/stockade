#!/usr/bin/env bash
# Launch the Stockade platform (proxy + orchestrator).
# Usage: stockade [--validate]

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

# ── Validate-only mode ──
if [[ "${1:-}" == "--validate" ]]; then
  exec node --import tsx packages/orchestrator/src/validate.ts
fi

# ── Preflight checks ──
if ! command -v docker &>/dev/null; then
  echo "[stockade] warning: docker not found — container isolation disabled"
fi

if ! command -v node &>/dev/null; then
  echo "[stockade] error: node is required" >&2
  exit 1
fi

# ── Cleanup handler ──
PROXY_PID=""
cleanup() {
  echo ""
  echo "[stockade] shutting down..."
  if [[ -n "$PROXY_PID" ]]; then
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

# ── Start proxy (background) ──
echo "[stockade] starting proxy..."
node --import tsx packages/proxy/src/index.ts &
PROXY_PID=$!

# Give proxy a moment to bind ports before orchestrator tries to connect
sleep 1

# ── Start orchestrator (foreground — owns terminal I/O) ──
echo "[stockade] starting orchestrator..."
node --import tsx packages/orchestrator/src/index.ts
