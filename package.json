{
  "name": "stockade",
  "version": "0.1.0-alpha",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm -r --parallel dev",
    "start": "bash bin/stockade",
    "start:orchestrator": "node --import tsx packages/orchestrator/src/index.ts",
    "start:worker": "node --import tsx packages/worker/src/index.ts",
    "start:proxy": "node --import tsx packages/proxy/src/index.ts",
    "start:validate": "bash bin/stockade --validate",
    "setup": "bash bin/setup.sh",
    "setup:no-docker": "bash bin/setup.sh --no-docker"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "cpu-features",
      "esbuild",
      "ssh2"
    ]
  }
}