#!/bin/sh
# apw — Agent Platform credential store CLI
# Reads value from stdin, stores via the gateway API.
#
# Usage:
#   echo "secret_value" | apw store <key> [--host H --header H --format F]
#
# Env vars:
#   APW_GATEWAY  — Gateway URL (e.g., http://localhost:10256)
#   APW_TOKEN    — Bearer token for gateway auth

set -e

if [ -z "$APW_GATEWAY" ] || [ -z "$APW_TOKEN" ]; then
  echo "Error: APW_GATEWAY and APW_TOKEN must be set" >&2
  exit 1
fi

COMMAND="${1:-}"
shift 2>/dev/null || true

case "$COMMAND" in
  read)
    KEY="${1:-}"
    if [ -z "$KEY" ]; then
      echo "Usage: apw read <key>" >&2
      exit 1
    fi

    RESPONSE=$(curl -s -w "\n%{http_code}" \
      -H "Authorization: Bearer $APW_TOKEN" \
      "${APW_GATEWAY}/gateway/ref/${KEY}")

    HTTP_CODE=$(printf '%s\n' "$RESPONSE" | tail -n1)
    BODY_RESP=$(printf '%s\n' "$RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
      # Extract the ref token from JSON and print it raw (no newline)
      echo "$BODY_RESP" | grep -o '"ref":"[^"]*"' | cut -d'"' -f4 | tr -d '\n'
    else
      echo "Error ($HTTP_CODE): $BODY_RESP" >&2
      exit 1
    fi
    ;;

  reveal)
    KEY="${1:-}"
    if [ -z "$KEY" ]; then
      echo "Usage: apw reveal <key>" >&2
      exit 1
    fi

    RESPONSE=$(curl -s -w "\n%{http_code}" \
      -H "Authorization: Bearer $APW_TOKEN" \
      "${APW_GATEWAY}/gateway/reveal/${KEY}")

    HTTP_CODE=$(printf '%s\n' "$RESPONSE" | tail -n1)
    BODY_RESP=$(printf '%s\n' "$RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
      # Extract the value from JSON and print it raw (no newline)
      echo "$BODY_RESP" | grep -o '"value":"[^"]*"' | cut -d'"' -f4 | tr -d '\n'
    else
      echo "Error ($HTTP_CODE): $BODY_RESP" >&2
      exit 1
    fi
    ;;

  store)
    KEY="${1:-}"
    shift 2>/dev/null || true

    if [ -z "$KEY" ]; then
      echo "Usage: apw store <key> [--host H --header H --format F]" >&2
      exit 1
    fi

    # Parse optional route metadata flags
    HOST=""
    HEADER=""
    FORMAT=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --host)   HOST="$2"; shift 2 ;;
        --header) HEADER="$2"; shift 2 ;;
        --format) FORMAT="$2"; shift 2 ;;
        *)        echo "Unknown option: $1" >&2; exit 1 ;;
      esac
    done

    # Read value from stdin
    VALUE="$(cat)"
    if [ -z "$VALUE" ]; then
      echo "Error: no value provided on stdin" >&2
      exit 1
    fi

    # Build JSON body
    if [ -n "$HOST" ] && [ -n "$HEADER" ]; then
      if [ -n "$FORMAT" ]; then
        BODY=$(printf '{"value":"%s","route":{"host":"%s","header":"%s","format":"%s"}}' \
          "$VALUE" "$HOST" "$HEADER" "$FORMAT")
      else
        BODY=$(printf '{"value":"%s","route":{"host":"%s","header":"%s"}}' \
          "$VALUE" "$HOST" "$HEADER")
      fi
    else
      BODY=$(printf '{"value":"%s"}' "$VALUE")
    fi

    # POST to gateway
    RESPONSE=$(curl -s -w "\n%{http_code}" \
      -X POST \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $APW_TOKEN" \
      -d "$BODY" \
      "${APW_GATEWAY}/gateway/store/${KEY}")

    HTTP_CODE=$(printf '%s\n' "$RESPONSE" | tail -n1)
    BODY_RESP=$(printf '%s\n' "$RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
      echo "Stored: $KEY"
    else
      echo "Error ($HTTP_CODE): $BODY_RESP" >&2
      exit 1
    fi
    ;;

  list)
    RESPONSE=$(curl -s -w "\n%{http_code}" \
      -H "Authorization: Bearer $APW_TOKEN" \
      "${APW_GATEWAY}/gateway/list")

    HTTP_CODE=$(printf '%s\n' "$RESPONSE" | tail -n1)
    BODY_RESP=$(printf '%s\n' "$RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
      printf '%s\n' "$BODY_RESP" | python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
items = d.get('vaultItems') or d.get('keys', [])
for item in sorted(items):
    print(item)
"
    else
      echo "Error ($HTTP_CODE): $BODY_RESP" >&2
      exit 1
    fi
    ;;

  ssh)
    TARGET="${1:-}"
    if [ -z "$TARGET" ]; then
      echo "Usage: apw ssh [user@]host [command...]" >&2
      exit 1
    fi
    shift

    # Extract host from user@host or plain host
    HOST=$(echo "$TARGET" | sed 's/.*@//')
    COMMAND="$*"

    # JSON-encode via Python to handle special chars in command
    BODY=$(python3 -c "
import json, sys
print(json.dumps({'host': sys.argv[1], 'command': sys.argv[2]}))
" "$HOST" "$COMMAND")

    RESPONSE=$(curl -s -w "\n%{http_code}" \
      -X POST \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $APW_TOKEN" \
      -d "$BODY" \
      "${APW_GATEWAY}/gateway/ssh-exec")

    HTTP_CODE=$(printf '%s\n' "$RESPONSE" | tail -n1)
    BODY_RESP=$(printf '%s\n' "$RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
      printf '%s' "$BODY_RESP" | python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
if d.get('error'):
    sys.stderr.write('ssh-exec error: ' + d['error'] + '\n')
    sys.exit(1)
sys.stdout.write(d.get('stdout', ''))
if d.get('stderr'):
    sys.stderr.write(d['stderr'])
sys.exit(d.get('exitCode', 0))
"
    else
      echo "Error ($HTTP_CODE): $BODY_RESP" >&2
      exit 1
    fi
    ;;

  *)
    echo "Usage:" >&2
    echo "  apw list                                    — list available credential keys" >&2
    echo "  apw read <key>                              — get a ref token for a credential" >&2
    echo "  apw reveal <key>                            — get the raw credential value" >&2
    echo "  apw store <key> [--host H --header H --format F]  — store a credential from stdin" >&2
    echo "  apw ssh [user@]host [command...]            — run a command via the SSH proxy" >&2
    exit 1
    ;;
esac
